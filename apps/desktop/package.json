{
  "name": "@mps/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "echo \"@mps/desktop lint placeholder\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "build:ui": "vite build --base ./",
    "build": "pnpm run typecheck && pnpm run test && pnpm run build:ui",
    "build:release": "node ../../scripts/release/package-desktop-release.mjs",
    "tauri:dev": "tauri dev --config src-tauri/tauri.conf.json",
    "tauri:build": "tauri build --config src-tauri/tauri.conf.json",
    "e2e": "echo \"@mps/desktop e2e placeholder\"",
    "e2e:desktop": "vitest run --config vitest.config.ts test/gates/mandatory-v1-gates.test.ts && node ../../scripts/verify-thresholds.mjs --platform desktop --metrics ../../.sisyphus/evidence/task-16-desktop-gates.metrics.json"
  },
  "dependencies": {
    "@mps/core": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^22.10.10",
    "jsdom": "^24.1.3",
    "typescript": "^5.7.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
