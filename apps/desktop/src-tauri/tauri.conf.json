{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Media Poster Space",
  "version": "0.1.0",
  "identifier": "space.media.poster",
  "build": {
    "beforeDevCommand": "pnpm --filter @mps/desktop dev",
    "beforeBuildCommand": "pnpm --filter @mps/desktop run build:ui",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Media Poster Space",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
